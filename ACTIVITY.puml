@startuml ACTIVITY_WF4
title FMPDF — WF4 : Creation Marche Manuel → Confirmation Reception

skinparam activity {
  BackgroundColor #F0F9FF
  BorderColor     #2563EB
  ArrowColor      #1E40AF
  DiamondBackgroundColor #FEF9C3
  DiamondBorderColor     #D97706
}
skinparam swimlane {
  BorderColor #94A3B8
  TitleBackgroundColor #E2E8F0
}

|Gestionnaire Magasin|
start
:Remplir le formulaire (POST /procurement/marches/)\navec tous les articles;
note right
  type_acquisition: marche | bon_commande | donation
  source = "manuel"
  Choisir statut a la creation
end note

:Choisir le statut a la creation;

if (Statut = Receptionne et stocke ?) then (Oui)
  |Systeme|
  :Articles integres au stock immediatement\n(_find_or_create_ressource + _integrate_item);
  :statut MarcheBC -> "receptionne_et_stocke";
  :date_reception = now();
  :Creer MouvementStock (type=entree) par article;
  :MarcheBC visible dans Marches / BC / Dons;

  |Gestionnaire Magasin|
  :Consulter le stock mis a jour\n(GET /api/resources/stocks/);
  stop

else (Statut = En attente de livraison)
  |Systeme|
  :MarcheBC cree statut = "en_attente_livraison";
  :Articles enregistres mais PAS dans le stock;
  :Calculer delai_reception_jours\n(90j marche / 40j BC / 0j don);
  :Calculer date_livraison_prevue;
  :Creer les MarcheEtapes par defaut\n(marche_cree -> complete, reste en_attente);
  :Creer AlerteDelai si delai proche (tache periodique);

  |Gestionnaire Magasin|
  :MarcheBC visible avec bouton "Confirmer reception";
  :Attendre la livraison physique;
  :Verifier les articles livres vs commande;
  :Cliquer "Confirmer reception"\n(POST /procurement/marches/{id}/confirmer-reception/);

  |Systeme|
  :statut MarcheBC -> "receptionne_et_stocke";
  :date_reception = now();
  :Integrer articles au stock :\n  consommable -> quantite_disponible += quantite\n  bien inventaire -> creer instances en_stock;
  :Creer MouvementStock (type=entree) par ressource;
  :MarcheEtapes -> complete :\n  en_attente_livraison, livraison_en_cours,\n  receptionne_magasin, controle_qualite;

  |Gestionnaire Magasin|
  :Consulter le stock mis a jour\n(GET /api/resources/stocks/);
  stop
endif

@enduml
