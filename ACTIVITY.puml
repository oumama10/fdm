@startuml ACTIVITY_WF1
title FMPDF — WF1 : Import PDF/Excel → Validation → Stock

skinparam activity {
  BackgroundColor #F0F9FF
  BorderColor     #2563EB
  ArrowColor      #1E40AF
  DiamondBackgroundColor #FEF9C3
  DiamondBorderColor     #D97706
}
skinparam swimlane {
  BorderColor #94A3B8
  TitleBackgroundColor #E2E8F0
}

|Gestionnaire Magasin|
start
:Uploader un fichier PDF / Excel\n(POST /procurement/import/direct/);
note right
  file_type = "pdf" ou "xlsx"
  source_type = bc | marche | donation
end note

|Systeme (Celery)|
:Creer ImportExcelBC (statut = "brouillon");
:Declencher tache OCR / extraction;
:Extraire les articles -> creer StagingItems\n(statut = "en_attente");
:Mettre a jour statut import -> "en_attente";

|Gestionnaire Magasin|
:Consulter les imports a reviser\n(GET /procurement/import/?scope=extraites);
:Ouvrir l'import et reviser chaque article;

repeat
  :Examiner un article staging;
  if (Article correct sans modification ?) then (Oui)
    :Approuver l article directement\n(POST /procurement/staging/{id}/approve/);
    :statut staging -> "approuve";
  elseif (Article necessite correction ?) then (Oui)
    :Modifier la designation / type_detecte\ncategorie / sous-categorie / quantite / prix\n(PATCH /procurement/staging/{id}/);
    :statut staging -> "modifie";
    :Approuver l article corrige\n(POST /procurement/staging/{id}/approve/);
    :statut staging -> "approuve";
  else (Non recuperable)
    :Rejeter l article\n(POST /procurement/staging/{id}/reject/);
    :statut staging -> "rejete";
  endif
repeat while (Il reste des articles en attente ?) is (Oui) not (Non)

|Systeme (Signal post_save)|
:Signal on_staging_approuve declenche;
if (Ressource existe deja ?) then (Oui)
  :Recuperer la ressource existante;
else (Non)
  :Creer la ressource (Ressource.objects.create);
endif

if (Ressource est consommable ?) then (Oui)
  :Mettre a jour Stock\n(quantite_disponible += quantite);
  :Creer MouvementStock (type=entree);
else (Bien Inventaire)
  :Creer instances InstanceRessource\n(statut=en_stock, numero=INV-YYYY-N);
  :Creer MouvementStock (type=entree);
endif

:_check_import_complete();
if (Tous les articles traites ?) then (Oui)
  if (Au moins un approuve ?) then (Oui)
    :statut import -> "valide";
    :_sync_marche_reference();
    :statut MarcheBC -> "receptionne_et_stocke";
    :_complete_reception_etapes() — 4 etapes -> complete;
  else (Tous rejetes)
    :statut import -> "rejete";
  endif
endif

|Gestionnaire Magasin|
:Consulter le stock mis a jour;
stop

@enduml

