@startuml ACTIVITY_WF3
title FMPDF — WF3 : Retour de Materiel

skinparam activity {
  BackgroundColor #F0F9FF
  BorderColor     #2563EB
  ArrowColor      #1E40AF
  DiamondBackgroundColor #FEF9C3
  DiamondBorderColor     #D97706
}
skinparam swimlane {
  BorderColor #94A3B8
  TitleBackgroundColor #E2E8F0
}

|Chef de Service|
start
:Identifier le materiel a retourner;
:Creer le retour\n(POST /api/returns/retours/);
note right
  motif_retour: panne | inutilise
  id_ressource + id_instance_ressource
  statut -> "en_attente"
end note

|Systeme|
:Notifier le gestionnaire (RETOUR_ENREGISTRE);

|Gestionnaire Magasin|
:Consulter les retours en attente\n(GET /api/returns/retours/);
:Inspecter physiquement le materiel;
:Receptionner le retour (PATCH statut -> "receptionne");
:date_reception = now();

:Lire le motif du retour;
if (Motif = panne ?) then (Oui)
  :InstanceRessource.statut -> hors_service;
  :InstanceRessource.etat -> hors_service;
  :service_affecte -> null;
  note right
    Materiel hors service definitif
    ou en attente de reparation externe
  end note
else (Motif = inutilise)
  :InstanceRessource.statut -> retourne;
  :service_affecte -> null;
  note right
    Visible dans l inventaire comme "Retourne".
    Le gestionnaire peut manuellement
    le passer en "en_stock" apres inspection.
  end note
endif

:Appliquer la decision\n(PATCH /api/returns/retours/{id}/);
:Renseigner justification_decision;
stop

@enduml

