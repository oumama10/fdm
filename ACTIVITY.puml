@startuml ACTIVITY_WF2
title FMPDF — WF2 : Demande → Validation → Decharge → Signature

skinparam activity {
  BackgroundColor #F0F9FF
  BorderColor     #2563EB
  ArrowColor      #1E40AF
  DiamondBackgroundColor #FEF9C3
  DiamondBorderColor     #D97706
}
skinparam swimlane {
  BorderColor #94A3B8
  TitleBackgroundColor #E2E8F0
}

|Chef de Service|
start
:Creer une demande\n(POST /api/requests/demandes/);
note right
  urgence: normal | moyen | urgent
  lignes: id_ressource + quantite_demandee
  statut -> "en_attente"
end note
:Attendre la decision du gestionnaire;

|Systeme|
:Notifier le gestionnaire (DEMANDE_SOUMISE);

|Gestionnaire Magasin|
:Consulter les demandes en attente\n(GET /api/requests/demandes/);
:Verifier la disponibilite en stock;
:Renseigner quantite_accordee par ligne;
:Prendre une decision\n(POST /api/requests/demandes/{id}/valider/);
note right
  decision = "total" | "partiel" | "refus"
end note

if (Decision = refus ?) then (Oui)
  :statut Demande -> "refusee";
  :motif_refus renseigne;
  :Notifier le chef de service (DEMANDE_REJETEE);
  |Chef de Service|
  :Recevoir notification de refus;
  stop
elseif (Decision = total ?) then (Oui)
  :quantite_accordee = quantite_demandee par ligne;
  :statut Demande -> "totale";
else (Decision = partiel)
  :quantite_accordee < quantite_demandee sur au moins une ligne;
  :statut Demande -> "partielle";
endif

|Systeme|
:Decharge creee automatiquement dans valider()\n(Decharge + LigneDecharge);
note right
  Consommable -> LigneDecharge quantite=qa
  Bien Inventaire -> LigneDecharge par instance
  SignatureDecharge creee (statut=non_signe)
end note
:PDF de decharge genere (tache generate_decharge_pdf);
:Notifier le chef de service (DECHARGE_GENEREE);

|Chef de Service|
:Recevoir notification DECHARGE_GENEREE;
:Telecharger le PDF decharge\n(GET /api/decharge/decharges/{id}/pdf/);
:Signer physiquement le document papier;
note right
  Aucune action dans le systeme a cette etape.
  La signature se fait sur le document papier.
end note

|Gestionnaire Magasin|
:Recevoir le document physique signe;
:Verifier la signature physique;
:Confirmer la signature dans le systeme\n(POST /decharges/{id}/signature/confirmer/);
note right
  statut signature : non_signe -> signe
  date_signature = now()
end note

|Systeme|
:Signal on_signature_valide declenche;
:quantite_livree = quantite_accordee par LigneDemande;
:Mettre a jour progression Demande (totale ou partielle);
:Creer MouvementStock (type=sortie);
:Notifier chef de service (DECHARGE_SIGNEE);

|Chef de Service|
:Recevoir notification confirmation signature;
stop

@enduml

